# Document root is the Laravel project root (Hostinger public_html). Forward every
# request into the Laravel public/ folder so the app is served from there without
# changing the hosting document root. Project files (app/, config/, .env, vendor/)
# stay outside the served path.
<IfModule mod_rewrite.c>
    RewriteEngine On

    # If the request is not already pointing at /public, rewrite it there.
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# Never list directories
Options -Indexes

# Block direct access to sensitive files (defense in depth)
<Files ~ "\.(env|json|config\.js|md|gitignore|gitattributes|lock|log|sql|sh|ps1|py|yml|yaml)$">
    Order allow,deny
    Deny from all
</Files>

## GZIP / DEFLATE COMPRESSION ##
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE application/json application/xml application/rss+xml
    AddOutputFilterByType DEFLATE image/svg+xml application/vnd.ms-fontobject
    AddOutputFilterByType DEFLATE application/x-font-ttf font/ttf font/otf font/woff font/woff2
</IfModule>
# LiteSpeed (Hostinger) compression
<IfModule LiteSpeed>
    SetEnv noabort 1
</IfModule>

## EXPIRES CACHING ##
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType application/vnd.ms-fontobject "access plus 1 year"
    ExpiresDefault "access plus 1 days"
</IfModule>

## CACHE-CONTROL (immutable static assets) ##
<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|woff2?|ttf|otf|eot|svg|jpe?g|png|gif|webp|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>
